{
  "name": "expert-match-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "test": "vitest --run tests/unit",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "smoke:api": "node -e \"const wait = (ms) => new Promise((resolve) => setTimeout(resolve, ms)); const run = async () => { for (let attempt = 0; attempt < 20; attempt += 1) { try { const response = await fetch('http://backend:8000/readyz'); if (response.ok) { return; } } catch {} await wait(1000); } process.exit(1); }; run();\""
  },
  "dependencies": {
    "@tanstack/react-query": "^5.66.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^24.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vitest": "^3.0.7"
  }
}
