APP_ENV=development
APP_BASE_URL=http://localhost:8000
APP_FRONTEND_URL=http://localhost:5173
APP_EMBEDDING_PROVIDER=specter2
APP_EMBEDDING_MODEL_NAME=allenai/specter2_base
APP_EMBEDDING_DOCUMENT_ADAPTER_NAME=allenai/specter2
APP_EMBEDDING_QUERY_ADAPTER_NAME=allenai/specter2_adhoc_query
APP_EMBEDDING_DIMENSION=768

# Local Compose Postgres service bootstrap values.
POSTGRES_DB=expert_match
POSTGRES_USER=expert_match
POSTGRES_PASSWORD=expert_match

# Backend application database connection string. Keep this in sync with the
# local Postgres service values above unless you intentionally point at a
# different database.
POSTGRES_DSN=postgresql+psycopg://expert_match:expert_match@postgres:5432/expert_match
VITE_API_BASE=
VITE_PROXY_TARGET=http://backend:8000
